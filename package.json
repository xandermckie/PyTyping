{
  "name": "pytyping",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "PyTyping — a minimalist Python learning game inspired by Monkeytype.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview",
    "gen:exercises": "node scripts/generate-exercises.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "lz-string": "^1.5.0",
    "prismjs": "^1.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/lz-string": "^1.3.34",
    "@types/prismjs": "^1.26.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^3.2.4"
  }
}
